{
  "expo": {
    "name": "eye-tracking-camera",
    "slug": "eye-tracking-camera",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Precisamos acessar sua câmera."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "android": {
      "package": "com.gabriel.eyetrackingcamera"
    }
  }
}